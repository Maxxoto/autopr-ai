{
  "name": "autopr",
  "version": "0.1.0",
  "description": "CLI tool for automated PR review, smart commits, and PR creation",
  "type": "module",
  "bin": {
    "autopr": "./dist/index.js"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit"
  },
  "keywords": ["cli", "github", "pr", "automation", "git"],
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "@octokit/rest": "^22.0.1",
    "@octokit/plugin-paginate-rest": "^14.0.0",
    "simple-git": "^3.36.0",
    "@inquirer/prompts": "^8.4.2",
    "ora": "^9.4.0",
    "picocolors": "^1.1.1",
    "conf": "^15.1.0",
    "openai": "^6.34.0",
    "node-notifier": "^10.0.1",
    "open": "^10.1.0"
  },
  "devDependencies": {
    "typescript": "^5.9.2",
    "tsx": "^4.21.0",
    "vitest": "^4.1.4",
    "@types/node": "^24.5.2",
    "@types/node-notifier": "^8.0.5"
  }
}
